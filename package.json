{
  "name": "documentation",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "prestart": "npm run gen-api-docs",
    "build": "docusaurus build",
    "prebuild": "npm run gen-api-docs",
    "swizzle": "docusaurus swizzle",
    "clear": "docusaurus clear",
    "serve": "node serve.js",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "gen-api-docs": "docusaurus gen-api-docs all --plugin-id ads-api && docusaurus gen-api-docs all --plugin-id ad-engine-api && docusaurus gen-api-docs all --plugin-id millicast-api && docusaurus gen-api-docs all --plugin-id theolive-api",
    "clean-api-docs": "docusaurus clean-api-docs all --plugin-id ads-api && docusaurus clean-api-docs all --plugin-id ad-engine-api && docusaurus clean-api-docs all --plugin-id millicast-api && docusaurus clean-api-docs all --plugin-id theolive-api",
    "typecheck": "tsc",
    "check-format": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint docusaurus.config.ts \"sidebars*.ts\" src",
    "fix-lint": "npm run lint -- --fix",
    "spellcheck": "mdxlint",
    "spellcheck-all": "npm run spellcheck -- \"**/*.md\" \"**/*.mdx\" \"!**/external/**/*\""
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.2",
    "@docusaurus/faster": "^3.9.2",
    "@docusaurus/plugin-client-redirects": "^3.9.2",
    "@docusaurus/plugin-google-gtag": "^3.9.2",
    "@docusaurus/plugin-google-tag-manager": "^3.9.2",
    "@docusaurus/preset-classic": "^3.9.2",
    "@mdx-js/react": "^3.1.1",
    "@webcoder49/code-input": "^2.8.1",
    "clsx": "^2.1.1",
    "docusaurus-plugin-image-zoom": "^3.0.1",
    "docusaurus-plugin-openapi-docs": "^4.7.1",
    "docusaurus-theme-openapi-docs": "^4.7.1",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-aria-components": "^1.15.1",
    "react-dom": "^19.2.4",
    "schema-dts": "^1.1.5",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.9.2",
    "@docusaurus/tsconfig": "^3.9.2",
    "@docusaurus/types": "^3.9.2",
    "@eslint/js": "~9.39.2",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "dictionary-en": "^4.0.0",
    "dotenv": "^17.3.1",
    "eslint": "~9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "lodash": "^4.17.23",
    "mdast-util-mdx": "^3.0.0",
    "mdxlint": "^1.0.0",
    "micromark-extension-mdx-expression": "^3.0.1",
    "micromark-extension-mdx-jsx": "^3.0.2",
    "micromark-extension-mdx-md": "^2.0.0",
    "micromark-extension-mdxjs-esm": "^3.0.0",
    "micromark-util-combine-extensions": "^2.0.1",
    "prettier": "^3.8.1",
    "raw-loader": "^4.0.2",
    "remark-mdx": "^3.1.1",
    "remark-retext": "^6.0.1",
    "retext-english": "^5.0.0",
    "retext-indefinite-article": "^5.0.0",
    "retext-repeated-words": "^5.0.0",
    "retext-spell": "^6.1.0",
    "retext-syntax-urls": "^4.0.0",
    "serve-handler": "^6.1.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "overrides": {
    "@docusaurus/utils": {
      "gray-matter": "npm:@gr2m/gray-matter@4.0.3-with-pr-137"
    },
    "docusaurus-theme-openapi-docs": {
      "react": "$react"
    }
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0"
  }
}
